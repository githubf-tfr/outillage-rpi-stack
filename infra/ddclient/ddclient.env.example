# Modele de ddclient.env -- variables Compose (ou "Environment variables"
# d'une Stack Portainer via portainer-stack, cf. CLAUDE.md a la racine de ce
# repo pour le mecanisme complet). Ne jamais committer le fichier reel ici.

# Nom du conteneur -- formalisme nomdelastack_xxx, juste "nomdelastack" si
# un seul conteneur dans la stack (cas ici).
DDCLIENT_CONTAINER_NAME=ddclient

# Image linuxserver.io : PUID/PGID (utilisateur hote proprietaire des
# fichiers montes, cf. docs linuxserver.io) et TZ (fuseau horaire des logs).
DDCLIENT_PUID=1000
DDCLIENT_PGID=1000
DDCLIENT_TZ=Europe/Paris

# Chemin hote vers le ddclient.conf reel (adapte depuis
# ddclient.conf.example), monte en lecture seule dans le conteneur.
DDCLIENT_CONFIG_PATH=/srv/docker/ddclient/ddclient.conf

# Sous-reseau Docker interne dedie a cette stack, TOUJOURS en /24. IP fixe
# de ddclient dedans -- convention d'adressage rpi-stack : .100 = serveur/
# web, .10 = bdd (ici, un seul conteneur, .100). Allocation officielle (cf.
# plan d'adressage reseau dans README.md) : 2eme /24 du bloc infrastructure
# 10.1.0.0/16.
DDCLIENT_NETWORK_SUBNET=10.1.1.0/24
DDCLIENT_NETWORK_IP=10.1.1.100

# Nom de reseau Docker et nom d'interface bridge -- deux variables
# distinctes (formalisme "net_xxx" pour les deux), a garder identiques par
# convention sauf besoin explicite de les decoupler.
DDCLIENT_NETWORK_NAME=net_ddclient
DDCLIENT_NETWORK_IFACE=net_ddclient
