# Identifiants API OVH (PAS ceux du DynHost de ddclient) pour le provider
# DNS-01 "ovh" de Traefik/lego -- generes sur https://api.ovh.com/createToken/.
# Sans effet si dnsChallenge n'est pas active dans traefik.yml.
OVH_ENDPOINT=ovh-eu
OVH_APPLICATION_KEY=change-me
OVH_APPLICATION_SECRET=change-me
OVH_CONSUMER_KEY=change-me
