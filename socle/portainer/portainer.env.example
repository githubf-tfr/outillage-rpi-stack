# Modele de portainer.env -- copier a cote de compose.yaml (meme dossier),
# remplir avec les vraies valeurs du deploiement consommateur, ne jamais
# committer le fichier reel dans CE repo (generique, sans valeur concrete).
# Le pourquoi de chaque valeur reste ici, en exemple.

# Nom du conteneur -- formalisme nomdelastack_xxx, juste "nomdelastack" si
# un seul conteneur dans la stack (cas ici).
PORTAINER_CONTAINER_NAME=portainer

# IP sur laquelle Portainer expose son UI (port 9000 interne). A choisir
# selon ton reseau -- eviter 0.0.0.0 si tu veux limiter l'exposition
# (cf. compose.yaml). Exemple ci-dessous : plage documentaire RFC 5737,
# a remplacer par une IP reelle de ton hote/reseau.
PORTAINER_BIND_ADDR=192.0.2.10

# Sous-reseau Docker interne dedie a cette stack (jamais route vers
# l'exterieur de l'hote), TOUJOURS en /24. IP fixe de Portainer dedans --
# convention d'adressage rpi-stack : .100 = serveur/web, .10 = bdd
# (ici, un seul conteneur, .100). Allocation officielle (cf. plan
# d'adressage reseau dans README.md) : 1er /24 du bloc socle
# 10.1.0.0/16.
PORTAINER_NETWORK_SUBNET=10.1.0.0/24
PORTAINER_NETWORK_IP=10.1.0.100

# Nom de reseau Docker et nom d'interface bridge -- deux variables
# distinctes (formalisme "net_xxx" pour les deux), a garder identiques par
# convention (cf. compose.yaml) sauf besoin explicite de les decoupler.
PORTAINER_NETWORK_NAME=net_portainer
PORTAINER_NETWORK_IFACE=net_portainer

# Chemin hote (doit deja exister, cf. compose.yaml) ou Portainer persiste
# ses donnees -- typiquement sur la partition dediee aux donnees de stacks.
PORTAINER_DATA_DIR=/srv/docker/portainer/data

# Portainer ne rejoint PAS le reseau partage net_proxy et n'a aucun label
# traefik.* -- s'il faut le mettre en TLS derriere Traefik, ca se fait cote
# traefik (provider file, IP:port = PORTAINER_BIND_ADDR ci-dessus), pas ici.
# Cf. socle/traefik/dynamic/portainer.yml.example et README.md "Pourquoi
# Portainer n'est pas sur net_proxy".
