# Valeurs non secretes de la stack Traefik, consommees par compose.yaml
# (syntaxe Compose ${VAR}). Le detail de la config (entrypoints, resolveur
# ACME, routes) vit dans traefik.yml + dynamic/*.yml (fichiers complets,
# non decoupables en ${VAR} -- meme convention que ddclient.conf).

# Nom du conteneur -- un seul conteneur dans la stack, pas de suffixe
# (convention rpi-stack : nomdelastack_xxx sinon).
TRAEFIK_CONTAINER_NAME=traefik

# Adresse de bind des ports 80/443 sur l'hote -- PAS 0.0.0.0 par defaut :
# Docker contourne ufw pour ses ports publies (chaine FORWARD/DNAT), un
# bind large exposerait le proxy sur toutes les interfaces de l'hote, y
# compris celles non voulues. A fixer explicitement par le consommateur
# (interface d'administration dediee, ou IP publique/uplink si exposition
# volontaire vers l'exterieur -- decision propre au deploiement).
TRAEFIK_BIND_ADDR=192.0.2.10
TRAEFIK_HTTP_PORT=80
TRAEFIK_HTTPS_PORT=443

# Fichiers/dossiers de config (fournis par le consommateur, montes en
# lecture seule) -- cf. traefik.yml.example et dynamic/.
TRAEFIK_STATIC_CONFIG_PATH=/chemin/vers/traefik.yml
TRAEFIK_DYNAMIC_CONFIG_DIR=/chemin/vers/dynamic

# Stockage persistant des certificats ACME (Let's Encrypt) -- dossier hote.
# Doit contenir un fichier acme.json PRE-CREE en chmod 600 AVANT le premier
# demarrage :
#   mkdir -p <TRAEFIK_ACME_DIR> && touch <TRAEFIK_ACME_DIR>/acme.json
#   chmod 600 <TRAEFIK_ACME_DIR>/acme.json
# (Traefik refuse d'ecrire les certs si les permissions sont trop larges --
# piege classique.)
TRAEFIK_ACME_DIR=/srv/docker/traefik/letsencrypt

# Sous-reseau Docker interne dedie a cette stack (le reseau "maison" de
# Traefik, PAS le reseau de routage -- cf. compose.yaml), TOUJOURS en /24.
# IP fixe de Traefik dedans -- convention d'adressage rpi-stack : .100 =
# serveur/web (ici, un seul conteneur, .100). Allocation officielle (cf.
# plan d'adressage reseau dans README.md) : 1er /24 du bloc "services
# communs" 10.2.0.0/16.
TRAEFIK_NETWORK_SUBNET=10.2.0.0/24
TRAEFIK_NETWORK_IP=10.2.0.100

# Nom de reseau Docker et nom d'interface bridge -- deux variables
# distinctes cote template, gardees identiques ici par convention.
TRAEFIK_NETWORK_NAME=net_traefik
TRAEFIK_NETWORK_IFACE=net_traefik

# Reseau PARTAGE de routage (cf. compose.yaml et README, section "Reseau
# proxy partage") : les stacks backend LOCALES qui veulent etre routees via
# le provider Docker le rejoignent en plus de leur propre reseau prive.
# CREE par cette stack (Traefik = bootstrap du reseau de routage, meme
# logique que Portainer pour les stacks Docker) -- les stacks qui le
# rejoignent le declarent "external: true" chez elles, meme nom. Sous-reseau
# fixe : 10.0.0.0/16, reserve a ce reseau partage (cf. README.md).
TRAEFIK_PROXY_NETWORK_NAME=net_proxy
TRAEFIK_PROXY_NETWORK_SUBNET=10.0.0.0/16

# IP fixe de Traefik lui-meme sur net_proxy -- formalisme 10.0.X.Y : X = code
# categorie (2 = sc), Y = 3e octet du /24 prive ci-dessus (0). Coherence du
# plan d'adressage meme si Traefik n'est jamais une cible routee sur ce
# reseau (il en est le createur/routeur).
TRAEFIK_PROXY_IP=10.0.2.0
