# exemple.env.example — modele pour l'exemple de conventions rpi-stack.
# Illustre : sous-reseau /24 fixe, IP fixe par conteneur (.100 = web,
# .10 = bdd), nom de reseau/interface identiques (net_xxx), noms de volumes
# et de conteneurs prefixes par le nom de la stack (nomdelastack_xxx).

# --- Reseau ---
# Sous-reseau dedie a la stack, TOUJOURS en /24. Volontairement hors du plan
# d'adressage reel (10.0.0.0/16 proxy, 10.1.0.0/16 socle, 10.2.0.0/16
# metiers, cf. README.md) puisque cet exemple n'est pas
# une stack deployee -- ne pas reutiliser 172.30.1.0/24 pour un vrai service.
EXEMPLE_NETWORK_SUBNET=172.30.1.0/24
# Nom de reseau Docker et nom d'interface bridge -- deux variables
# distinctes (formalisme "net_xxx" pour les deux), a garder identiques par
# convention sauf besoin explicite de les decoupler.
EXEMPLE_NETWORK_NAME=net_exemple
EXEMPLE_NETWORK_IFACE=net_exemple

# --- Conteneur web (serveur) -- .100 dans le sous-reseau ---
EXEMPLE_WEB_IMAGE=example/web:latest
EXEMPLE_WEB_CONTAINER_NAME=exemple_web
EXEMPLE_WEB_IP=172.30.1.100
EXEMPLE_WEB_DATA_DIR=/srv/docker/exemple/web

# --- Conteneur db (bdd) -- .10 dans le sous-reseau ---
EXEMPLE_DB_IMAGE=example/db:latest
EXEMPLE_DB_CONTAINER_NAME=exemple_db
EXEMPLE_DB_IP=172.30.1.10
EXEMPLE_DB_DATA_DIR=/srv/docker/exemple/db
